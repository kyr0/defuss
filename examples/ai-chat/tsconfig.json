{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "defuss",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "resolveJsonModule": true,
    "types": ["astro/client"],
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": "."
  },
  "include": ["src", "test", "astro.config.ts", ".astro/types.d.ts"]
}

{
  "name": "defuss-extension",
  "version": "0.0.1",
  "manifest_version": 3,
  "description": "Versatile, cross-browser extension template built with defuss, demonstrating RPC communication between a background worker and content scripts for automating web tasks, as well as integration with a server-side task queue, a popup UI, script injection, blob/file storage, database persistency, preference management, large file zero-copy operations, and keep-alive functionality.",
  "icons": {
    "16": "icons/icon.png",
    "32": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_title": "defuss-extension anzeigen",
    "default_popup": "src/popup/popup.html"
  },
  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "css": ["src/tab-preload-border.css"],
      "js": ["src/tab-preload.ts"],
      "all_frames": true,
      "match_origin_as_fallback": false,
      "match_about_blank": false,
      "world": "MAIN"
    },
    {
      "matches": ["http://*/*", "https://*/*", "file://*/*"],
      "js": ["src/tab.ts"],
      "all_frames": false,
      "match_origin_as_fallback": false,
      "match_about_blank": false,
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],
  "host_permissions": ["*://*/*", "http://127.0.0.1/*", "http://localhost/*"],
  "permissions": [
    "webRequest",
    "scripting",
    "tabs",
    "activeTab",
    "storage",
    "unlimitedStorage",
    "offscreen",
    "alarms"
  ],
  "background": {
    "service_worker": "src/worker.ts",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self';"
  },
  "incognito": "split",
  "web_accessible_resources": [
    {
      "resources": [
        "src/offscreen/keepalive.html",
        "src/offscreen/keepalive.js"
      ],
      "matches": ["<all_urls>"],
      "use_dynamic_url": false
    },
    {
      "resources": ["dist/*"],
      "matches": ["http://*/*", "https://*/*", "file://*/*"]
    },
    {
      "resources": ["fonts/*"],
      "matches": ["http://*/*", "https://*/*", "file://*/*"]
    },
    {
      "resources": ["models/*"],
      "matches": ["http://*/*", "https://*/*", "file://*/*"]
    }
  ]
}

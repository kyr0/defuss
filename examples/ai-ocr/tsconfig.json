{
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "defuss",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2022",
    "resolveJsonModule": true,
    "types": ["astro/client"],
    "strict": true,
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@components/*": ["src/csr/components/*"],
      "@layouts/*": ["src/layouts/*"]
    }
  },
  "include": ["src", "i18n", "astro.config.ts", ".astro/types.d.ts"]
}

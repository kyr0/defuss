---
const rpcEndpoint = Astro.locals.rpcEndpoint;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>defuss-rpc Chat Streaming</title>
  </head>
  <body>
    <div id="app"></div>
    <script define:vars={{ rpcEndpoint }}>
      window.__RPC_ENDPOINT__ = rpcEndpoint;
    </script>
    <script type="module" src="/src/chat-client.tsx"></script>
  </body>
</html>

{
  "name": "defuss-embeddings",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "description": "Isomorphic text embeddings with Harrier ONNX int8 plus exact and TurboQuant-style vector search.",
  "keywords": [
    "defuss",
    "embeddings",
    "onnx",
    "transformers.js",
    "vector-search",
    "turboquant",
    "browser",
    "node"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyr0/defuss.git"
  },
  "author": "OpenAI",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/shared.cjs",
  "module": "./dist/shared.mjs",
  "types": "./dist/shared.d.mts",
  "exports": {
    ".": {
      "require": {
        "types": "./dist/shared.d.cts",
        "default": "./dist/shared.cjs"
      },
      "import": {
        "types": "./dist/shared.d.mts",
        "default": "./dist/shared.mjs"
      }
    },
    "./client.js": {
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      },
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      }
    },
    "./server.js": {
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      },
      "import": {
        "types": "./dist/server.d.mts",
        "default": "./dist/server.mjs"
      }
    },
    "./vector-search.js": {
      "require": {
        "types": "./dist/vector-search.d.cts",
        "default": "./dist/vector-search.cjs"
      },
      "import": {
        "types": "./dist/vector-search.d.mts",
        "default": "./dist/vector-search.mjs"
      }
    },
    "./turboquant.js": {
      "require": {
        "types": "./dist/turboquant.d.cts",
        "default": "./dist/turboquant.cjs"
      },
      "import": {
        "types": "./dist/turboquant.d.mts",
        "default": "./dist/turboquant.mjs"
      }
    }
  },
  "scripts": {
    "clean": "rm -rf ./dist ./.vitest ./.coverage",
    "prebuild": "bun run clean",
    "build": "pkgroll",
    "test:node": "vitest run --config vitest.config.ts",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "test:needle": "vitest run --config vitest.needle.config.ts",
    "test:needle:live": "vitest run --config vitest.needle.live.config.ts",
    "test:live:node": "vitest run --config vitest.live.config.ts",
    "test:live:browser": "vitest run --config vitest.live.browser.config.ts",
    "test:live": "bun run test:live:node && bun run test:live:browser",
    "pretest": "bun run build",
    "test": "bun run test:node && bun run test:browser",
    "prepublishOnly": "bun run test"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=18.17.1"
  },
  "dependencies": {
    "@huggingface/transformers": "^3.8.1",
    "defuss-db": "^1.1.4"
  },
  "devDependencies": {
    "@vitest/browser-playwright": "^4.0.18",
    "pkgroll": "^2.25.2",
    "playwright": "^1.55.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

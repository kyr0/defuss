{
  "name": "defuss-brotli",
  "version": "0.1.2",
  "type": "module",
  "license": "MIT",
  "description": "A pure-Rust Brotli WebAssembly package with split compressor/decompressor exports for small build sizes.",
  "author": "Aron Homberg <info@aron-homberg.de>",
  "packageManager": "bun@1.3.9",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyr0/defuss.git"
  },
  "keywords": [
    "brotli",
    "compression",
    "decompression",
    "rust",
    "wasm",
    "webassembly",
    "isomorphic",
    "npm",
    "defuss"
  ],
  "sideEffects": false,
  "files": [
    "dist",
    "wasm/pkg",
    "README.md",
    "LICENSE",
    "THIRD_PARTY_NOTICES.md"
  ],
  "exports": {
    "./compressor": {
      "import": {
        "types": "./dist/compressor.d.ts",
        "default": "./dist/compressor.js"
      }
    },
    "./decompressor": {
      "import": {
        "types": "./dist/decompressor.d.ts",
        "default": "./dist/decompressor.js"
      }
    }
  },
  "scripts": {
    "setup": "bun scripts/setup.ts",
    "clean": "bun scripts/clean.ts",
    "build": "bun scripts/build.ts",
    "pretest": "bun run build",
    "test": "vitest run --coverage",
    "pretest:browser": "bun run build",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "example": "bun run build && bun examples/quality-comparison.ts",
    "test:e2e": "bun run build && bun e2e/e2e.ts",
    "bench": "bun run build && vitest bench --run --config vitest.bench.config.ts",
    "bench:browser": "bun run build && vitest bench --run --config vitest.bench.browser.config.ts",
    "prepublishOnly": "bun run build"
  },
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vite-plugin-wasm": "^3.5.0",
    "vitest": "^4.0.18"
  }
}

{
  "name": "defuss-express",
  "version": "0.2.1",
  "type": "module",
  "license": "MIT",
  "description": "Extremely performant (!), express-compatible, auto-multi-core, QUIC/HTTP/3-enabled, WebSocket-capable, load-balanced, ultimate-express-powered server runtime for defuss.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kyr0/defuss.git"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "homepage": "https://github.com/kyr0/defuss",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.9",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "build": "pkgroll",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "dev": "node --import tsx ./examples/basic.ts",
    "example:basic": "node --import tsx ./examples/basic.ts",
    "example:advanced": "node --import tsx ./examples/advanced.ts",
    "example:file-delivery": "node --import tsx ./examples/file-delivery.ts",
    "example:websocket": "node --import tsx ./examples/websocket.ts",
    "example:file-upload": "node --import tsx ./examples/file-upload.ts",
    "example:sse": "node --import tsx ./examples/server-sent-events.ts",
    "bench": "node --import tsx ./bench/throughput.ts",
    "bench:server": "node --import tsx ./bench/dson-server.ts",    
    "prepublishOnly": "bun run build"
  },
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "types": "./dist/index.d.cts",
  "dependencies": {
    "defuss-open-telemetry": "^0.1.0",
    "ultimate-express": "^2.0.17"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "defuss-dson": "^1.1.1",
    "defuss-jwt": "^1.0.1",
    "pkgroll": "^2.27.0",
    "tsx": "^4.19.4",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

{
  "name": "defuss-orchestrator",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": { "access": "public" },
  "packageManager": "bun@1.3.9",
  "license": "MIT",
  "description": "Federated pull-based work orchestrator with rendezvous hashing, sticky ownership, async durability, and pluggable worker/work selection.",
  "keywords": [
    "orchestrator",
    "scheduler",
    "queue",
    "rendezvous-hashing",
    "distributed",
    "eventual-consistency",
    "typescript",
    "defuss"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "prebuild": "bun run clean",
    "build": "pkgroll",
    "test": "vitest --run --coverage",
    "bench": "vitest bench --run"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": ["dist"],
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >=21.0.0"
  },
  "dependencies": {
    "defuss-hash": "^0.1.0",
    "defuss-open-telemetry": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "pkgroll": "^2.27.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

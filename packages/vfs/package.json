{
  "name": "defuss-vfs",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "bun@1.3.9",
  "license": "MIT",
  "description": "Isomorphic virtual file system with Memory backing for Web and Node.js.",
  "keywords": [
    "vfs",
    "virtual",
    "file",
    "system",
    "memory",
    "isomorphic",
    "defuss"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "prebuild": "bun run clean",
    "build": "pkgroll",
    "test": "vitest run --coverage",
    "prepublishOnly": "bun run build"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >=21.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.0.17",
    "pkgroll": "^2.21.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}

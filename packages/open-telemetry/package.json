{
  "name": "defuss-open-telemetry",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": { "access": "public" },
  "license": "MIT",
  "description": "Small OpenTelemetry bridge package for defuss metrics sinks.",
  "keywords": [
    "opentelemetry",
    "telemetry",
    "metrics",
    "defuss"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "scripts": {
    "clean": "rm -rf ./dist",
    "prebuild": "bun run clean",
    "build": "pkgroll",
    "test": "vitest --run --coverage"
  },
  "author": "Aron Homberg",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": ["dist"],
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >=21.0.0"
  },
  "devDependencies": {
    "pkgroll": "^2.27.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18"
  }
}

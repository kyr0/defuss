{
  "name": "defuss-vad",
  "type": "module",
  "version": "2.0.1",
  "keywords": [
    "vad",
    "voice-activity-detection",
    "wasm",
    "isomorphic"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "license": "MIT",
  "author": {
    "name": "Aron Homberg",
    "email": "info@aron-homberg.de",
    "url": "https://aron-homberg.de"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    "./firered-web": {
      "types": "./dist/firered-web.d.ts",
      "import": "./dist/firered-web.js"
    },
    "./firered-node": {
      "types": "./dist/firered-node.d.ts",
      "import": "./dist/firered-node.js"
    },
    "./firered-webgpu": {
      "types": "./dist/firered-webgpu.d.ts",
      "import": "./dist/firered-webgpu.js"
    },
    "./tenvad": {
      "types": "./dist/tenvad-web.d.ts",
      "node": "./dist/tenvad-node.js",
      "default": "./dist/tenvad-web.js"
    },
    "./tenvad-web": {
      "types": "./dist/tenvad-web.d.ts",
      "import": "./dist/tenvad-web.js"
    },
    "./tenvad-node": {
      "types": "./dist/tenvad-node.d.ts",
      "import": "./dist/tenvad-node.js"
    },
    "./firered": {
      "types": "./dist/firered-web.d.ts",
      "node": "./dist/firered-node.js",
      "default": "./dist/firered-web.js"
    },
    "./silero": {
      "types": "./dist/silero-web.d.ts",
      "node": "./dist/silero-node.js",
      "default": "./dist/silero-web.js"
    },
    "./silero-web": {
      "types": "./dist/silero-web.d.ts",
      "import": "./dist/silero-web.js"
    },
    "./silero-node": {
      "types": "./dist/silero-node.d.ts",
      "import": "./dist/silero-node.js"
    },
    "./types": {
      "types": "./dist/types.d.ts"
    },
    "./wav": {
      "types": "./dist/wav.d.ts",
      "import": "./dist/wav.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "models",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "bun run clean",
    "test": "bun run test:e2e && bun run test:e2e:browser",
    "test:e2e": "bunx vitest run --config vitest.config.ts --coverage",
    "test:e2e:browser": "bunx vitest run --config vitest.browser.config.ts --coverage",
    "build": "bun run test && pkgroll",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "pkgroll": "^2.27.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "dependencies": {
    "defuss-db": "^2.0.0",
    "onnxruntime-web": "1.22.0-dev.20250409-89f8206ba4"
  }
}

{
  "name": "defuss-openai",
  "type": "module",
  "version": "1.0.0",
  "keywords": [
    "openai",
    "fetch",
    "isomorphic"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "license": "MIT",
  "author": {
    "name": "Aron Homberg",
    "email": "info@aron-homberg.de",
    "url": "https://aron-homberg.de"
  },
  "packageManager": "bun@1.3.9",
  "engines": {
    "node": ">=18"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "types": "./dist/index.d.ts",
  "main": "./dist/index.js",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "test": "bun run test:e2e && bun run test:e2e:browser",
    "test:e2e": "bunx vitest run --config vitest.config.ts",
    "test:e2e:browser": "bunx vitest run --config vitest.browser.config.ts",
    "build": "bun run test && pkgroll",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "pkgroll": "^2.27.0",
    "playwright": "^1.59.1",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}

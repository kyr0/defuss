{
  "name": "defuss-hash",
  "version": "0.1.0",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "description": "A library of fast and stable special-purpose hashing functions: JIT-optimized content hashing with key-order stability and skip paths, rendezvous hashing, etc.",
  "keywords": [
    "hash",
    "content-hash",
    "json",
    "stable-hash",
    "isomorphic",
    "jit-optimized",
    "distributed-systems",
    "federated-systems",
    "deduplication",
    "defuss",
    "rendezvous-hash",
    "consistent-hash"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "scripts": {
    "clean": "rm -rf ./coverage ./dist ./node_modules/.vite",
    "prebuild": "bun run clean",
    "build": "bun scripts/build.ts",
    "pretest": "bun run build",
    "test": "vitest run --coverage",
    "test:browser": "vitest run --config vitest.browser.config.ts",
    "bench": "vitest bench --run --config vitest.bench.config.ts",
    "pretest:browser": "bun run build",
    "prebench": "bun run build"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "sideEffects": false,
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": "^20.0.0 || >=22.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@vitest/browser": "^4.0.18",
    "@vitest/browser-playwright": "^4.0.18",
    "@vitest/coverage-v8": "^4.0.18",
    "playwright": "^1.58.2",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}

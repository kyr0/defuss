{
  "name": "defuss-storybook",
  "version": "0.2.2",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "defuss-storybook": "dist/cli.mjs"
  },
  "license": "MIT",
  "description": "A lightweight storybook implementation for defuss. Zero-config, Vite-powered, with dynamic prop controls and Playwright testing.",
  "keywords": [
    "storybook",
    "defuss",
    "components",
    "ui",
    "testing",
    "playwright"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "scripts": {
    "clean": "rm -rf ./dist && rm -rf ./node_modules/.bun",
    "prebuild": "bun run clean",
    "build": "pkgroll --sourcemap",
    "test": "echo 'No tests available'",
    "prepublishOnly": "bun run build"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist",
    "app"
  ],
  "engines": {
    "node": "^18.17.1 || ^20.3.0 || >=21.0.0"
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "@tailwindcss/vite": "^4.1.18",
    "chokidar": "^5.0.0",
    "defuss": "^3.4.0",
    "defuss-vite": "^1.1.3",
    "fast-glob": "^3.3.3",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "rehype-katex": "^7.0.1",
    "tailwindcss": "^4.1.18",
    "vite": "^7.3.1"
  },
  "devDependencies": {
    "pkgroll": "^2.25.2",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "defuss-shadcn": ">=0.6.0"
  },
  "peerDependenciesMeta": {
    "defuss-shadcn": {
      "optional": false
    }
  },
  "packageManager": "bun@1.3.9"
}

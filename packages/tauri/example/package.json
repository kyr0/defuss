{
  "name": "defuss-ssg-example",
  "type": "module",
  "version": "0.0.2",
  "private": true,
  "scripts": {
    "clean": "rm -rf dist .defuss-tauri .endpoints .rpc node_modules/.vite",
    "tauri:init": "node ../dist/cli.js init . --debug",
    "predev": "bun run clean",
    "dev": "bunx defuss-ssg dev .",
    "build": "bunx defuss-ssg build .",
    "tauri:build": "node ../dist/cli.js build",
    "pretauri:dev": "bun run tauri:init",
    "tauri:dev": "node ../dist/cli.js dev"
  },
  "dependencies": {
    "defuss": "^3.4.8",
    "defuss-db": "^2.0.2",
    "defuss-rpc": "^1.6.2",
    "defuss-ssg": "^0.7.5"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "autoprefixer": "^10.4.21",
    "postcss": "^8.5.6",
    "sass-embedded": "^1.89.1",
    "tailwindcss": "^4.1.18"
  }
}
{
  "name": "defuss-ssg",
  "version": "0.7.2",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "defuss-ssg": "dist/cli.mjs"
  },
  "license": "MIT",
  "description": "A simple static site generator (SSG) built with and for defuss.",
  "keywords": [
    "ssg",
    "static",
    "site",
    "generator",
    "defuss"
  ],
  "repository": {
    "url": "git+https://github.com/kyr0/defuss.git",
    "type": "git"
  },
  "scripts": {
    "clean": "rm -rf ./dist && rm -rf ./node_modules/.bun && rm -rf ./.container-runtime",
    "pretest": "bun run build",
    "prebuild": "bun run clean",
    "build": "pkgroll && node ./scripts/append-virtual-config-types.mjs",
    "prepare:container": "node ./scripts/prepare-container-runtime.mjs",
    "test:browser": "vitest run --config vitest.browser.config.ts --passWithNoTests",
    "cli-dev": "node ./dist/cli.mjs dev ../../example-ssg/",
    "cli-dev:three": "node ./dist/cli.mjs dev ../../examples/with-three.js/",
    "cli-build": "node ./dist/cli.mjs build ../../example-ssg/",
    "cli-serve": "node ./dist/cli.mjs serve ../../example-ssg/",
    "cli-serve:mc": "node ./dist/cli.mjs serve ../../example-ssg/ --multicore",
    "test:cli-dev:three": "bun run build && vitest run scripts/cli-dev-three.spec.ts",
    "bench:rpc": "npx autocannon -p 256 -w 8 -c 1024 -d 30 -m POST -H 'content-type: application/json' -b '{\"className\":\"mathApi\",\"methodName\":\"add\",\"args\":[1,2]}' http://127.0.0.1:3000/rpc",
    "test": "bun run test:cli-dev:three",
    "bench": "npx autocannon -p 32 -w 8 -c 200 -d 20 -m POST -H \"content-type: application/json\" -b '{\"hello\":\"world\"}' http://127.0.0.1:3000/body",
    "start": "node ./dist/cli.mjs dev ../../example-ssg/",
    "prepublishOnly": "bun run test"
  },
  "author": "Aron Homberg <info@aron-homberg.de>",
  "sideEffects": false,
  "exports": {
    ".": {
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      },
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    },
    "./content": {
      "require": {
        "types": "./dist/content.d.cts",
        "default": "./dist/content.cjs"
      },
      "import": {
        "types": "./dist/content.d.mts",
        "default": "./dist/content.mjs"
      }
    },
    "./runtime": {
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      },
      "import": {
        "types": "./dist/runtime.d.mts",
        "default": "./dist/runtime.mjs"
      }
    },
    "./vite": {
      "require": {
        "types": "./dist/vite.d.cts",
        "default": "./dist/vite.cjs"
      },
      "import": {
        "types": "./dist/vite.d.mts",
        "default": "./dist/vite.mjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.cts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "peerDependencies": {
    "defuss-rpc": "*"
  },
  "peerDependenciesMeta": {
    "defuss-rpc": {
      "optional": false
    }
  },
  "dependencies": {
    "@mdx-js/rollup": "^3.1.0",
    "defuss": "^3.4.6",
    "defuss-express": "^0.3.2",
    "defuss-vite": "^1.2.0",
    "esbuild": "^0.27.3",
    "fast-glob": "^3.3.3",
    "rehype-katex": "^7.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-mdx-frontmatter": "^5.2.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "rolldown": "^1.0.0-rc.18",
    "toml": "^3.0.0",
    "vite": "^8.0.0",
    "ws": "^8.20.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@vitest/browser": "^4.0.17",
    "@vitest/browser-playwright": "^4.0.17",
    "@vitest/coverage-v8": "^4.0.17",
    "@types/autocannon": "^7.12.7",
    "@types/ws": "^8.18.1",
    "autocannon": "^8.0.0",
    "happy-dom": "^20.6.1",
    "pkgroll": "^2.25.2",
    "playwright": "^1.57.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  }
}